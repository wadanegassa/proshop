# ProShop Mobile Production Environment Configuration

# Step 1: Create a copy of this file named '.env.production'
# Step 2: Fill in your production values
# Step 3: Build the app using:
# flutter run --dart-define=API_URL=https://your-production-api.com/api/v1

# Base URL for the API
API_URL=https://proshop-api.example.com/api/v1

# Other production flags
ENVIRONMENT=production
DEBUG_LOGGING=false
